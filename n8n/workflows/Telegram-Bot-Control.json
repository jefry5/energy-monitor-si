    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst sIcon = { Critico: '🔴', Advertencia: '🟠', Normal: '🟢' };\n\nif (rows.length === 0) {\n  return [{ json: { text: '✅ <b>Sin anomalías en las últimas 6 horas.</b>\\n\\n🤖 <i>Sistema operando normalmente.</i>', chat_id: $('Normalizar Input').first().json.chat_id } }];\n}\n\nlet msg = `🚨 <b>ANOMALÍAS — ÚLTIMAS 6H</b>\\n━━━━━━━━━━━━━━━━━━━━\\n\\n`;\n\nrows.forEach((r, idx) => {\n  const icon = sIcon[r.severidad] || '⚪';\n  let rec = {};\n  try { rec = JSON.parse(r.recomendacion.replace(/```json|```/g, '')); } catch(e) { rec = {causa:'N/D', accion:'Verificar manualmente', prioridad:'Media'}; }\n  msg += `${icon} <b>#${idx+1} ${r.area}</b> — <code>${r.cuando}</code>\\n`;\n  msg += `   ⚡ ${r.valor_kwh} kWh (EMA: ${r.ema_kwh} | Δ${r.desviacion}%)\\n`;\n  msg += `   🧩 ${rec.causa || 'Sin diagnóstico'}\\n`;\n  msg += `   🛠️ ${rec.accion || 'Revisar'}\\n\\n`;\n});\n\nmsg += `━━━━━━━━━━━━━━━━━━━━\\n🤖 <i>Diagnóstico por Google Gemini</i>`;\n\nreturn [{ json: { text: msg, chat_id: $('Normalizar Input').first().json.chat_id } }];"
      },
