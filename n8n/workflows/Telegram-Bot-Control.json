    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  area,\n  ROUND(SUM(reading)::numeric, 2)                          AS total_kwh,\n  ROUND(AVG(reading)::numeric, 2)                          AS promedio_kwh,\n  ROUND(MAX(reading)::numeric, 2)                          AS pico_kwh,\n  ROUND(MIN(reading)::numeric, 2)                          AS minimo_kwh,\n  COUNT(*)                                                  AS lecturas,\n  MAX(severity)                                             AS estado_max\nFROM energy_history\nWHERE timestamp >= NOW() - INTERVAL '24 hours'\nGROUP BY area\nORDER BY total_kwh DESC;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        832,
        -96
      ],
      "id": "ab7930f2-04d1-4fd7-837d-11191116889f",
      "name": "Obtener Reporte 24h",
      "credentials": {
        "postgres": {
          "id": "95gB8C5UUHd1h0BA",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(i => i.json);\nconst totalGlobal = rows.reduce((s, r) => s + Number(r.total_kwh), 0);\nconst costoEstimado = (totalGlobal * 0.18).toFixed(2);\nconst co2Estimado = (totalGlobal * 0.233).toFixed(2);\n\nconst severityIcon = { Normal: '✅', Warning: '⚠️', Critical: '🚨' };\n\nlet msg = `📊 <b>REPORTE ENERGÉTICO — ÚLTIMAS 24H</b>\\n━━━━━━━━━━━━━━━━━━━━\\n`;\nmsg += `🕒 <i>${new Date().toLocaleString('es-ES', {timeZone:'America/Lima'})}</i>\\n\\n`;\n\nrows.forEach(r => {\n  const icon = severityIcon[r.estado_max] || '⚪';\n  msg += `${icon} <b>${r.area}</b>\\n`;\n  msg += `   ⚡ Total: <b>${r.total_kwh} kWh</b>\\n`;\n  msg += `   📈 Pico: ${r.pico_kwh} | Promedio: ${r.promedio_kwh} kWh\\n`;\n  msg += `   📉 Mínimo: ${r.minimo_kwh} kWh (${r.lecturas} lecturas)\\n\\n`;\n});\n\nmsg += `━━━━━━━━━━━━━━━━━━━━\\n`;\nmsg += `🏭 <b>RESUMEN GLOBAL</b>\\n`;\nmsg += `⚡ Total: <b>${totalGlobal.toFixed(2)} kWh</b>\\n`;\nmsg += `💰 Costo estimado: <b>S/. ${costoEstimado}</b>\\n`;\nmsg += `🌱 CO₂ emitido: <b>${co2Estimado} kg</b>\\n\\n`;\nmsg += `🤖 <i>Sistema de Monitoreo Inteligente v2</i>`;\n\nreturn [{ json: { text: msg, chat_id: $('Normalizar Input').first().json.chat_id } }];"
      },
